XRAY_FRONTEND_CONFIG_PATH=/data/frontend/config.json
XRAY_FRONTEND_ACCESS_LOG_PATH=/data/frontend/access.log
XRAY_FRONTEND_SERVICE_NAME=xray-frontend
XRAY_FRONTEND_USE_NSENTER=1
XRAY_FRONTEND_HOST_RUNTIME_DIR=/opt/xray-frontend
XRAY_BINARY_PATH=/data/frontend/xray
XRAY_CLIENT_META_PATH=/data/frontend/clients-meta.json
XRAY_RELAY_HOST=relay.example.com
XRAY_RELAY_PORT=9443
XRAY_RELAY_SERVICE_NAME=xray-relay
XRAY_RELAY_SSH_KEY_PATH=/run/secrets/relay_ssh_key
XRAY_RELAY_SSH_USER=deploy
XRAY_ONLINE_WINDOW_MINUTES=5
XRAY_EXPECTED_EGRESS_IP=203.0.113.10
XRAY_ADMIN_USER=admin
XRAY_ADMIN_PASSWORD=replace-me
XRAY_TOPOLOGY_CACHE_TTL_SECONDS=10
XRAY_RELAY_SSH_KEY_SOURCE=/path/to/relay_ssh_key
