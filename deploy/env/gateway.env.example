XRAY_FRONTEND_PORT=9444
XRAY_FRONTEND_SERVER_NAME=example.com
XRAY_FRONTEND_TARGET=example.com:443
XRAY_FRONTEND_FINGERPRINT=chrome
XRAY_FRONTEND_SHORT_IDS=6ba85179e30d4fc2,0123456789abcdef
XRAY_FRONTEND_REALITY_PRIVATE_KEY=replace-me
XRAY_FRONTEND_REALITY_PUBLIC_KEY=replace-me
# Set relay host to the private tunnel/IPSec address when using a protected inter-node segment.
XRAY_RELAY_HOST=relay.example.com
XRAY_RELAY_PORT=9443
XRAY_RELAY_UUID=replace-me
