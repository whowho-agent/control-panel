# Run bootstrap-standalone.sh on the gateway node.
# It will SSH into the egress node, run bootstrap-egress there,
# then configure the local gateway frontend to point at that egress host.

EGRESS_HOST=72.56.109.197
EGRESS_SSH_USER=root
EGRESS_SSH_PORT=22
# Optional: path to private key on gateway node
EGRESS_SSH_KEY_PATH=/root/.ssh/id_ed25519
